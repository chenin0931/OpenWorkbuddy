{
  "manifest_version": 3,
  "name": "OpenWorkbuddy Chrome Bridge",
  "version": "0.3.0",
  "description": "Connect a user-selected Chrome tab to the local OpenWorkbuddy desktop agent.",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "activeTab",
    "debugger",
    "nativeMessaging",
    "tabs"
  ],
  "background": {
    "service_worker": "dist/service-worker.js",
    "type": "module"
  },
  "action": {
    "default_title": "Bind this tab to OpenWorkbuddy",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    }
  },
  "minimum_chrome_version": "121"
}
